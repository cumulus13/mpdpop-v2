# mpdpop.env — configuration for mpdpop
# Lines starting with # are comments.
# os.environ always overrides values set here.

# ── MPD Connection ───────────────────────────────────────────────────────────
MPD_HOST     = 127.0.0.1
MPD_PORT     = 6600
MPD_PASSWORD =
MPD_TIMEOUT  = 5

# ── Cache ────────────────────────────────────────────────────────────────────
# Read order:  Redis → pickle files → SQLite
# Write:       all available layers on first fetch
#
# Redis  — fastest (in-memory), optional.  Requires: pip install redis
# redis://[:pass@]host:6379/0  (blank = skip)
CACHE_REDIS_URL  = redis://127.0.0.1:6379/0   
#
# Pickle — fast file-based cache, no dependencies.
# set false to disable
CACHE_PICKLE     = true         
# blank = auto (sibling dir of the DB file)
CACHE_PICKLE_DIR =              
#
# SQLite — always-on fallback.  Optionally use any SQLAlchemy-compatible DB.
#          Requires: pip install sqlalchemy  (falls back to raw sqlite3 if absent)
# blank = ~/.local/share/mpdpop/cache.db
CACHE_DB_URL     =              
#                               # postgresql://user:pass@host/db
#                               # mysql+pymysql://user:pass@host/db
CACHE_TTL_DAYS        = 30
CACHE_REVALIDATE_DAYS = 7

# ── API Keys ─────────────────────────────────────────────────────────────────
# Last.fm  — free key at https://www.last.fm/api/account/create
LASTFM_API_KEY   = c725344c28768a57a507f014bdaeca79

# Discogs  — personal token at https://www.discogs.com/settings/developers
DISCOGS_TOKEN    = TVZartVTOFDLMNzlxbzhLQYIaXbyQRel

# MusicBrainz needs no key; set your app name/version for the User-Agent
MUSICBRAINZ_APP  = mpdpop/1.0

# ── Cover Art ────────────────────────────────────────────────────────────────
COVER_SIZE          = 120          # thumbnail size in pixels (square)
COVER_BIG_SIZE      = 480          # big cover popup size in pixels (s key / click)
INFO_PANEL_BIO_H    = 150           # height of artist bio area in pixels
# blank = system temp dir
COVER_CACHE_DIR     =              

# ── Artist Bio ───────────────────────────────────────────────────────────────
BIO_MAX_CHARS = 600            # truncate bio to this many characters
BIO_LANG      = en             # Wikipedia language code (en, id, de, fr …)

# ── UI ───────────────────────────────────────────────────────────────────────
DIALOG_WIDTH  = 780
DIALOG_HEIGHT = 820
PAGE_STEP     = 10             # rows scrolled per PgUp/PgDn
CMD_HISTORY   = 50             # max command bar history entries
WINDOW_ICON   = mpdpop.png
